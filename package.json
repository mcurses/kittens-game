{
  "name": "kittens-mcp",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "lint:css": "stylelint 'packages/client-web/src/**/*.css'",
    "lint:css-coverage": "node scripts/check-css-coverage.mjs",
    "format": "biome format --write .",
    "check": "biome check ."
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
